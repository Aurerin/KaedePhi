<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.ExportPage"
             x:DataType="vm:ExportViewModel">

    <Grid RowDefinitions="*,Auto">
        <Border Grid.Row="0" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20" Width="500" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="&#xf56e;" Classes="fa-icon"
                                   FontSize="24" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.export_title}" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.export_output_format}" FontSize="13" Opacity="0.7"/>
                        <ComboBox ItemsSource="{Binding AvailableFormats}"
                                  SelectedItem="{Binding SelectedFormat}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <CheckBox Content="{x:Static loc:GuiLocalizationString.export_stream_writing}" IsChecked="{Binding UseStream}"/>

                    <CheckBox Content="{x:Static loc:GuiLocalizationString.export_indented_output}"
                              IsChecked="{Binding IndentedOutput}"
                              IsVisible="{Binding IsJsonFormat}"/>

                    <!-- Conversion options panel (shown only when export format differs from import) -->
                    <Border IsVisible="{Binding ShowConversionOptions}"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_options_title}" FontSize="14" FontWeight="SemiBold"/>

                            <!-- PE 转换选项 -->
                            <StackPanel Spacing="8" IsVisible="{Binding ShowPeOptions}">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_pe_options}" FontSize="12" Opacity="0.7"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_speed_ratio}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeSpeedConversionRatio}" Increment="0.1" FormatString="F4" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_easing_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeUnsupportedEasingPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeAlphaCutPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_tolerance}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeAlphaCutTolerance}" Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_speed_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeSpeedCutPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- PhigrosV3 转换选项 -->
                            <StackPanel Spacing="8" IsVisible="{Binding ShowPhigrosOptions}">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_phigros_options}" FontSize="12" Opacity="0.7"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_default_bpm}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PhigrosDefaultBpm}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_easing_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PhigrosEasingPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PhigrosAlphaCutPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_filter_fake_notes}" IsChecked="{Binding FilterFakeNotes}"/>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_negative_alpha_elevation}" IsChecked="{Binding NegativeAlphaElevation}"/>
                                    <StackPanel Spacing="4" IsVisible="{Binding NegativeAlphaElevation}">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_negative_alpha_step}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding NegativeAlphaStep}" Increment="0.5" FormatString="F1" Minimum="0.1" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- 通用选项 -->
                            <StackPanel Spacing="8" IsVisible="{Binding ShowGenericOptions}">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_common_options}" FontSize="12" Opacity="0.7"/>

                                <!-- 解绑选项 -->
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_section}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding UnbindPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_tolerance}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding UnbindTolerance}" Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_unbind_classic}" IsChecked="{Binding UnbindClassicMode}"/>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_unbind_compress}" IsChecked="{Binding UnbindCompress}"/>
                                </StackPanel>

                                <!-- 多层级合并选项 -->
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_section}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding MultiLayerMergePrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_tolerance}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding MultiLayerMergeTolerance}" Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_merge_classic}" IsChecked="{Binding MultiLayerMergeClassicMode}"/>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_merge_compress}" IsChecked="{Binding MultiLayerMergeCompress}"/>
                                </StackPanel>

                                <!-- 判定线过滤 -->
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_line_filter}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <StackPanel Spacing="6">
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_remove_attach_ui}" IsChecked="{Binding RemoveAttachUiLine}"/>
                                    <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_remove_texture}" IsChecked="{Binding RemoveTextureLine}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="1" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="12">
                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding HasStatusText}"/>

                <!-- Exporting indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8"
                            IsVisible="{Binding IsExporting}">
                    <TextBlock Text="&#xf110;" Classes="fa-icon" FontSize="16"
                               Foreground="{DynamicResource SystemAccentColor}">
                        <TextBlock.Styles>
                            <Style Selector="TextBlock">
                                <Style.Animations>
                                    <Animation Duration="0:0:1" IterationCount="Infinite">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </TextBlock.Styles>
                    </TextBlock>
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.status_exporting}" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                    <Button Padding="20,8" Click="OnReturnClick"
                            IsEnabled="{Binding !IsExporting}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xf060;" Classes="fa-icon"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_back_to_import}"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="accent" Padding="24,8" FontSize="14"
                            Content="{x:Static loc:GuiLocalizationString.btn_export}"
                            Click="OnExportClick"
                            IsEnabled="{Binding !IsExporting}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
