<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="*,Auto,Auto">
        <Border Grid.Row="0" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24" Width="560" HorizontalAlignment="Left">
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="&#xf013;" Classes="fa-icon"
                                   FontSize="24" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.settings_title}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- General -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.settings_max_log_files}" FontSize="12" Opacity="0.7"/>
                        <NumericUpDown Value="{Binding MaxLogFiles}" Minimum="1" Maximum="100"
                                       Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Unbind -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_unbind}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_precision}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding UnbindPrecision}" Minimum="1" Maximum="10000"
                                               Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_tolerance}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding UnbindTolerance}" Minimum="0" Maximum="100"
                                               Increment="0.1" FormatString="F2" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <CheckBox Content="{x:Static loc:GuiLocalizationString.option_classic_mode}" IsChecked="{Binding UnbindClassicMode}"/>
                            <CheckBox Content="{x:Static loc:GuiLocalizationString.option_disable_compress}"
                                      IsChecked="{Binding UnbindDisableCompress}"
                                      IsEnabled="{Binding UnbindDisableCompressEnabled}"
                                      ToolTip.Tip="{x:Static loc:GuiLocalizationString.option_disable_compress_hint}"/>
                        </StackPanel>
                    </Expander>

                    <!-- LayerMerge -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_layermerge}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_precision}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding LayerMergePrecision}" Minimum="1" Maximum="10000"
                                               Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_tolerance}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding LayerMergeTolerance}" Minimum="0" Maximum="100"
                                               Increment="0.1" FormatString="F2" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <CheckBox Content="{x:Static loc:GuiLocalizationString.option_classic_mode}" IsChecked="{Binding LayerMergeClassicMode}"/>
                            <CheckBox Content="{x:Static loc:GuiLocalizationString.option_disable_compress}"
                                      IsChecked="{Binding LayerMergeDisableCompress}"
                                      IsEnabled="{Binding LayerMergeDisableCompressEnabled}"
                                      ToolTip.Tip="{x:Static loc:GuiLocalizationString.option_disable_compress_hint}"/>
                        </StackPanel>
                    </Expander>

                    <!-- Cut -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_cut}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_precision}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding CutPrecision}" Minimum="1" Maximum="10000"
                                               Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_tolerance}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding CutTolerance}" Minimum="0" Maximum="100"
                                               Increment="0.1" FormatString="F2" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <CheckBox Content="{x:Static loc:GuiLocalizationString.option_disable_compress}" IsChecked="{Binding CutDisableCompress}"/>
                        </StackPanel>
                    </Expander>

                    <!-- Fit -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_fit}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_tolerance}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding FitTolerance}" Minimum="0" Maximum="100"
                                               Increment="0.5" FormatString="F1" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Render -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_render}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_pixels_per_beat}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderPixelsPerBeat}" Minimum="10" Maximum="1000"
                                                   Increment="10" FormatString="F0" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_channel_width}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderChannelWidth}" Minimum="50" Maximum="1000"
                                                   Increment="10" FormatString="F0" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_samples_per_event}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderSamplesPerEvent}" Minimum="4" Maximum="1024"
                                                   Increment="4" FormatString="F0" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_beat_subdivisions}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderBeatSubdivisions}" Minimum="1" Maximum="16"
                                                   Increment="1" FormatString="F0" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_range_padding_ratio}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderRangePaddingRatio}" Minimum="0" Maximum="1"
                                                   Increment="0.01" FormatString="F3" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_range_samples}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderRangeSamplesPerEvent}" Minimum="1" Maximum="1024"
                                                   Increment="1" FormatString="F0" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_segment_group_tolerance}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderSegmentGroupTolerance}" Minimum="0" Maximum="1"
                                                   Increment="0.000001" FormatString="F7" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_min_value_range_half}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding RenderMinValueRangeHalf}" Minimum="0" Maximum="100"
                                                   Increment="0.01" FormatString="F3" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_min_value_range_half_ratio}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding RenderMinValueRangeHalfRatio}" Minimum="0" Maximum="1"
                                               Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Convert -->
                    <Expander Header="{x:Static loc:GuiLocalizationString.settings_convert}">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <!-- PE options -->
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_pe_options}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <StackPanel Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_speed_ratio}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPeSpeedConversionRatio}" Increment="0.1" FormatString="F4" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_easing_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPeUnsupportedEasingPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPeAlphaCutPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_tolerance}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPeAlphaCutTolerance}" Minimum="0" Maximum="100"
                                                   Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_speed_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPeSpeedCutPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- PhigrosV3 options -->
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_phigros_options}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <StackPanel Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_default_bpm}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPhigrosDefaultBpm}" Minimum="1" Maximum="999"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_easing_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPhigrosEasingPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_alpha_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertPhigrosAlphaCutPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Common options -->
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_common_options}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>

                            <!-- Unbind -->
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_section}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <StackPanel Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertUnbindPrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_unbind_tolerance}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertUnbindTolerance}" Minimum="0" Maximum="100"
                                                   Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_unbind_classic}" IsChecked="{Binding ConvertUnbindClassicMode}"/>
                            </StackPanel>

                            <!-- Merge -->
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_section}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <StackPanel Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_precision}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertMultiLayerMergePrecision}" Minimum="1" Maximum="10000"
                                                   Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_merge_tolerance}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ConvertMultiLayerMergeTolerance}" Minimum="0" Maximum="100"
                                                   Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <CheckBox Content="{x:Static loc:GuiLocalizationString.convert_merge_classic}" IsChecked="{Binding ConvertMultiLayerMergeClassicMode}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="1" Padding="16,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7"/>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="2" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Padding="20,8" Click="OnReturnClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#xf060;" Classes="fa-icon"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_back}"/>
                    </StackPanel>
                </Button>
                <Button Padding="20,8" Click="OnResetClick">
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_reset_defaults}"/>
                </Button>
                <Button Classes="accent" Padding="24,8" FontSize="14" Click="OnSaveClick">
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_save_settings}"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
