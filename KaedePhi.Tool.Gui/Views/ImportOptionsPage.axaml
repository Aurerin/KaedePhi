<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.ImportOptionsPage"
             x:DataType="vm:ImportOptionsViewModel">

    <Grid RowDefinitions="*,Auto">
        <!-- 主内容 -->
        <Border Grid.Row="0" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20" Width="500" HorizontalAlignment="Left"
                            IsVisible="{Binding !IsLoading}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="&#xf013;" Classes="fa-icon"
                                   FontSize="24" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.import_options_title}" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.import_options_file}" FontSize="13" Opacity="0.7"/>
                        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.import_options_format}" FontSize="13" Opacity="0.7"/>
                        <TextBlock Text="{Binding FormatName}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- 转换选项面板 -->
                    <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.import_convert_options}" FontSize="14" FontWeight="SemiBold"/>

                            <!-- PhiEdit 导入选项 -->
                            <StackPanel Spacing="8" IsVisible="{Binding ShowPeOptions}">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_pe_options}" FontSize="12" Opacity="0.7"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_frame_duration_beat}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeFrameDurationBeat}" Increment="0.001" FormatString="F6" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_speed_ratio}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeSpeedConversionRatio}" Increment="0.1" FormatString="F4" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_trailing_beat_padding}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PeTrailingBeatPadding}" Increment="0.001" FormatString="F6" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- PhiChain 导入选项 -->
                            <StackPanel Spacing="8" IsVisible="{Binding ShowPhiChainOptions}">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_phichain_options}" FontSize="12" Opacity="0.7"/>
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Static loc:GuiLocalizationString.convert_easing_precision}" FontSize="12" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding PhiChainUnsupportedEasingPrecision}" Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 加载中覆盖层 -->
        <Border Background="#80000000"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <TextBlock Text="&#xf110;" Classes="fa-icon" FontSize="48"
                           Foreground="{DynamicResource SystemAccentColor}"
                           HorizontalAlignment="Center">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
                <TextBlock Text="{x:Static loc:GuiLocalizationString.import_loading}"
                           FontSize="16" Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="1" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Button Padding="20,8" Click="OnCancelClick"
                        IsEnabled="{Binding !IsLoading}"
                        IsVisible="{Binding !IsLoading}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#xf060;" Classes="fa-icon"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_back}"/>
                    </StackPanel>
                </Button>
                <Button Classes="accent" Padding="24,8" FontSize="14"
                        Content="{x:Static loc:GuiLocalizationString.import_options_confirm}"
                        Click="OnConfirmClick"
                        IsEnabled="{Binding !IsLoading}"
                        IsVisible="{Binding !IsLoading}"/>
                <Button Padding="24,8" FontSize="14"
                        Content="{x:Static loc:GuiLocalizationString.btn_cancel}"
                        Click="OnCancelImportClick"
                        IsVisible="{Binding IsLoading}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
