<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:m="using:KaedePhi.Tool.Gui.Models"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.ToolPage"
             x:DataType="vm:ToolViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <!-- Header: file info -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColor}" Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="&#xf07c;" Classes="fa-icon" FontSize="18"
                           VerticalAlignment="Center" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.header_file}" Foreground="White" Opacity="0.8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentFileName}" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Background="White" Opacity="0.2" Width="1" Margin="4,2"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.header_format}" Foreground="White" Opacity="0.8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DetectedFormat}" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tool cards -->
        <Border Grid.Row="1" Padding="16,12,16,0">
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static loc:GuiLocalizationString.tool_select_title}" FontSize="18" FontWeight="SemiBold"/>

                <ListBox ItemsSource="{Binding Tools}" SelectedItem="{Binding SelectedTool}"
                         SelectionMode="Single" Background="Transparent" BorderThickness="0" Padding="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="MinWidth" Value="220"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:ToolOption">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="avares://KaedePhi.Tool.Gui/Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free"
                                               FontWeight="Bold"
                                               FontSize="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.6"
                                           TextWrapping="Wrap" MaxWidth="220"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Tool options (scrollable) -->
        <Border Grid.Row="2" Padding="16,8"
                IsVisible="{Binding SelectedTool, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xf1de;" Classes="fa-icon"
                                       FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.tool_options_title}" FontWeight="SemiBold" FontSize="14"/>
                        </StackPanel>

                        <!-- Precision -->
                        <StackPanel IsVisible="{Binding ShowPrecision}" Spacing="4">
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.option_precision}" FontSize="12" Opacity="0.7"/>
                            <NumericUpDown Value="{Binding Precision}" Minimum="1" Maximum="10000"
                                           Increment="1" FormatString="F0" Width="200"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Tolerance -->
                        <StackPanel IsVisible="{Binding ShowTolerance}" Spacing="4">
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.option_tolerance}" FontSize="12" Opacity="0.7"/>
                            <NumericUpDown Value="{Binding Tolerance}" Minimum="0" Maximum="100"
                                           Increment="0.1" FormatString="F2" Width="200"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Classic mode -->
                        <CheckBox IsVisible="{Binding ShowClassicMode}"
                                  Content="{x:Static loc:GuiLocalizationString.option_classic_mode}"
                                  IsChecked="{Binding ClassicMode}"/>

                        <!-- Disable compress -->
                        <CheckBox IsVisible="{Binding ShowDisableCompress}"
                                  Content="{x:Static loc:GuiLocalizationString.option_disable_compress}"
                                  IsChecked="{Binding DisableCompress}"/>

                        <!-- Render options -->
                        <StackPanel IsVisible="{Binding ShowRenderOptions}" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_pixels_per_beat}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding PixelsPerBeat}" Minimum="10" Maximum="1000"
                                                   Increment="10" FormatString="F0" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_channel_width}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding ChannelWidth}" Minimum="50" Maximum="1000"
                                                   Increment="10" FormatString="F0" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_samples_per_event}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding SamplesPerEvent}" Minimum="4" Maximum="1024"
                                                   Increment="4" FormatString="F0" Width="140"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static loc:GuiLocalizationString.option_beat_subdivisions}" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding BeatSubdivisions}" Minimum="1" Maximum="16"
                                                   Increment="1" FormatString="F0" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Fit options -->
                        <StackPanel IsVisible="{Binding ShowFitOptions}" Spacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_segment_penalty}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding SegmentPenalty}" Minimum="0" Maximum="100"
                                               Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_keep_original_penalty}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding KeepOriginalPenalty}" Minimum="0" Maximum="100"
                                               Increment="0.01" FormatString="F3" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_full_search_threshold}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding FullSearchRunLengthThreshold}" Minimum="1" Maximum="10000"
                                               Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_long_run_window}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding LongRunSearchWindow}" Minimum="1" Maximum="10000"
                                               Increment="1" FormatString="F0" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Static loc:GuiLocalizationString.option_phase_epsilon}" FontSize="12" Opacity="0.7"/>
                                <NumericUpDown Value="{Binding PhaseDetectionEpsilon}" Minimum="0" Maximum="1"
                                               Increment="0.001" FormatString="F4" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="16,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7"/>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="4" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Padding="12,8" Click="OnReturnClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xf060;" Classes="fa-icon"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_back_to_import}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="12,8" Click="OnSettingsClick"
                            IsEnabled="{Binding !IsProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xf013;" Classes="fa-icon"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:GuiLocalizationString.btn_settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                    <Button Content="{x:Static loc:GuiLocalizationString.btn_run_tool}" Classes="accent" Padding="24,8" FontSize="14"
                            Click="OnRunClick"
                            IsEnabled="{Binding CanRun}"/>
                    <Button Content="{x:Static loc:GuiLocalizationString.btn_export_chart}" Padding="24,8" FontSize="14"
                            Click="OnExportClick"
                            IsEnabled="{Binding !IsProcessing}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
