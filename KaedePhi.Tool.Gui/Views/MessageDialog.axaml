<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KaedePhi.Tool.Gui.Views.MessageDialog"
        Title="KaedePhi"
        Width="400" MinHeight="180"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*,Auto">
        <Border Grid.Row="0" Padding="24,20">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Name="IconText" FontSize="24"
                               FontFamily="avares://KaedePhi.Tool.Gui/Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="MessageText" FontSize="14" TextWrapping="Wrap"
                           Opacity="0.8"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="OkButton" Content="OK" Classes="accent"
                        Padding="24,6" MinWidth="80"
                        Click="OnOkClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
