<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.ImportPage"
             x:DataType="vm:ImportViewModel"
             DragDrop.AllowDrop="True">

    <Grid>
        <!-- Center import button -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20"
                    IsVisible="{Binding !IsLoading}">
            <Image Source="avares://KaedePhi.Tool.Gui/Assets/KaedePhiIcon.png"
                   Width="120" Height="120"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Static loc:GuiLocalizationString.app_title}"
                       FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemAccentColor}"/>
            <TextBlock Text="{x:Static loc:GuiLocalizationString.app_subtitle}"
                       FontSize="14" Opacity="0.6"
                       HorizontalAlignment="Center"/>
            <Button Classes="accent"
                    HorizontalAlignment="Center"
                    Padding="40,16"
                    FontSize="16"
                    Click="OnImportClick">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="&#xf07c;" Classes="fa-icon" FontSize="20"/>
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.import_button}"/>
                </StackPanel>
            </Button>
            <TextBlock Text="{x:Static loc:GuiLocalizationString.import_drop_hint}"
                       FontSize="12" Opacity="0.4"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding !IsLoading}"/>
        </StackPanel>

        <!-- Drop overlay -->
        <Border Name="DropOverlay"
                Background="#4000A0FF"
                BorderBrush="{DynamicResource SystemAccentColor}"
                BorderThickness="3"
                CornerRadius="12"
                IsVisible="False"
                ZIndex="50"
                Margin="16">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="&#xf019;" Classes="fa-icon" FontSize="48"
                           Foreground="{DynamicResource SystemAccentColor}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Static loc:GuiLocalizationString.import_drop_active}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemAccentColor}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Loading overlay -->
        <Border Background="#80000000"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <TextBlock Text="&#xf110;" Classes="fa-icon" FontSize="48"
                           Foreground="{DynamicResource SystemAccentColor}"
                           HorizontalAlignment="Center">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
                <TextBlock Text="{x:Static loc:GuiLocalizationString.import_loading}"
                           FontSize="16" Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Bottom-right stream checkbox -->
        <CheckBox Content="{x:Static loc:GuiLocalizationString.import_stream_loading}"
                  IsChecked="{Binding UseStream}"
                  IsVisible="{Binding !IsLoading}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="24"/>
    </Grid>
</UserControl>
