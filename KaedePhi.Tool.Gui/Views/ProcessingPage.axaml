<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KaedePhi.Tool.Gui.ViewModels"
             xmlns:loc="using:KaedePhi.Tool.Localization"
             x:Class="KaedePhi.Tool.Gui.Views.ProcessingPage"
             x:DataType="vm:ProcessingViewModel">

    <Grid Background="#80000000">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="12" Padding="48,36" MinWidth="360">
            <StackPanel Spacing="20">

                <!-- Header with spinner -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="&#xf110;" Classes="fa-icon"
                               FontSize="28" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemAccentColor}">
                        <TextBlock.Styles>
                            <Style Selector="TextBlock">
                                <Style.Animations>
                                    <Animation Duration="0:0:1" IterationCount="Infinite">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </TextBlock.Styles>
                    </TextBlock>
                    <TextBlock Text="{x:Static loc:GuiLocalizationString.processing_title}"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Progress bar -->
                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                             CornerRadius="3"/>

                <!-- Tool sub-progress bar -->
                <ProgressBar Value="{Binding ToolProgressValue}" Maximum="100" Height="3"
                             CornerRadius="1" Opacity="0.7"/>

                <!-- Current step -->
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentStep}" FontWeight="SemiBold" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.6"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
